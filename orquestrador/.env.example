# orquestrador/.env.example — copie para orquestrador/.env e preencha os valores.
# Em produção (Railway), defina estas variáveis na aba Variables do serviço.
# A porta NÃO precisa ser definida aqui: o Railway injeta PORT automaticamente.

# --- Infra ---
DATABASE_URL=                 # PostgreSQL (o Railway injeta ao adicionar o plugin Postgres)
CADASTRO_ALLOWED_ORIGINS=     # CORS do /cadastro: origens EXTRAS por vírgula. Os domínios de produção (https://imoveis.imobiliariaaprovar.com.br e https://imobiliaria-aprovar.netlify.app) já são permitidos por padrão no código; use isto só para previews/outros domínios.

# --- Crítica (validação do webhook da landing) ---
WEBHOOK_SECRET=

# --- WhatsApp (Z-API) ---
ZAPI_INSTANCE_ID=
ZAPI_INSTANCE_TOKEN=
ZAPI_CLIENT_TOKEN=
CORRETOR_WHATSAPP=5548991719186   # número do corretor p/ notificações (só dígitos). IMPORTANTE: use um número DIFERENTE do da instância Z-API — a automação não entrega de forma confiável da linha pra ela mesma.

# --- CRM (Praedium) ---
PRAEDIUM_WEBHOOK_IN_URL=      # URL do Webhook de Entrada do Praedium (vazio = pula o envio)
PRAEDIUM_API_KEY=

# --- E-mail (Brevo) e IA (Gemini) ---
BREVO_API_KEY=
BREVO_LIST_ID=                # lista geral que dispara a automação de e-mails
BREVO_LIST_ID_VIP=            # lista VIP (cadastro da landing via POST /cadastro)
BREVO_LIST_ID_VIP_B=          # lista VIP da LP NOVA (fonte 'lp-botanique-nova'). DEFINA-A: se ficar vazia, o contato dessa fonte não entra em lista (Brevo é pulado) — o WhatsApp da M0 ainda sai.
GEMINI_API_KEY=

# --- Meta (CAPI / Pixel) ---
META_CAPI_TOKEN=
META_PIXEL_ID=
META_GRAPH_VERSION=           # ex.: v21.0 (default no código). Confira a versão vigente em developers.facebook.com/docs/graph-api/changelog e use a atual.
META_AD_ACCOUNT_ID=
META_PAGE_ID=                 # ID da página (Botanique: 104610745886365)
META_BUSINESS_ID=

# --- Meta Lead Ads (webhook do formulário nativo: /webhook/meta-lead) ---
META_APP_SECRET=              # App Secret do app Meta — valida a assinatura X-Hub-Signature-256 (sem ele, o POST do webhook responde 403)
META_VERIFY_TOKEN=            # string aleatória que VOCÊ escolhe; a mesma vai no painel (Webhooks → Verify Token)
META_PAGE_ACCESS_TOKEN=       # Page Access Token long-lived (System User) com permissão leads_retrieval
META_LEAD_FIELD_OBJETIVO=     # key do campo "objetivo" (morar/investir/construir) no Instant Form; vazio = tenta "objetivo"
META_LEAD_FIELD_OPTIN=        # key da pergunta de opt-in WhatsApp no Instant Form; sem valor afirmativo → optin=false (NÃO envia M0 ativa)

# --- M0 ativa proativa (mensagem outbound ao lead com opt-in) ---
M0_ATIVA_ENABLED=             # 'true' (default) liga a M0 ativa; 'false' desliga (corretor ainda é notificado)

# --- Fluxo "materiais" da LP nova (fonte 'lp-botanique-nova') ---
# Para essa fonte, a 1ª mensagem (M0 ativa) entrega os materiais; estes links são
# preenchidos em {{mapa}}/{{tabela}}. Sem valor, a mensagem mostra "-" (não quebra).
BOTANIQUE_MAPA_URL=           # link público do mapa dos 441 lotes (1º WhatsApp da LP nova)
BOTANIQUE_TABELA_URL=         # link público da tabela de preços de lançamento

# --- Captura de inbound no WhatsApp (número desconhecido que chama a Z-API) ---
WHATSAPP_INBOUND_CAPTURE_ENABLED=   # 'false' (default): NÃO cria lead/automação p/ número desconhecido que chega no WhatsApp — só LP (/cadastro) e Meta Lead Ads viram lead. 'true': captura o inbound (cria lead + Praedium + M0 + régua). Opt-out e escalada funcionam sempre.
