# orquestrador/.env.example — copie para orquestrador/.env e preencha os valores.
# Em produção (Railway), defina estas variáveis na aba Variables do serviço.
# A porta NÃO precisa ser definida aqui: o Railway injeta PORT automaticamente.

# --- Infra ---
DATABASE_URL=                 # PostgreSQL (o Railway injeta ao adicionar o plugin Postgres)

# --- Crítica (validação do webhook da landing) ---
WEBHOOK_SECRET=

# --- WhatsApp (Z-API) ---
ZAPI_INSTANCE_ID=
ZAPI_INSTANCE_TOKEN=
ZAPI_CLIENT_TOKEN=
CORRETOR_WHATSAPP=            # número do corretor p/ notificações (só dígitos, ex.: 5565999999999)

# --- CRM (Praedium) ---
PRAEDIUM_WEBHOOK_IN_URL=      # URL do Webhook de Entrada do Praedium (vazio = pula o envio)
PRAEDIUM_API_KEY=

# --- E-mail (Brevo) e IA (Gemini) ---
BREVO_API_KEY=
BREVO_LIST_ID=                # ID da lista do Brevo que dispara a automação de e-mails
GEMINI_API_KEY=

# --- Meta (CAPI / Pixel) ---
META_CAPI_TOKEN=
META_PIXEL_ID=
META_GRAPH_VERSION=           # ex.: v21.0 (default no código se vazio)
META_AD_ACCOUNT_ID=
META_PAGE_ID=
META_BUSINESS_ID=
