# orquestrador/.env.example — copie para orquestrador/.env e preencha os valores.
# Em produção (Railway), defina estas variáveis na aba Variables do serviço.
# A porta NÃO precisa ser definida aqui: o Railway injeta PORT automaticamente.

# --- Crítica (validação do webhook) ---
WEBHOOK_SECRET=

# --- Integrações (preenchidas conforme cada serviço é configurado) ---
PRAEDIUM_API_KEY=
ZAPI_INSTANCE_ID=
ZAPI_INSTANCE_TOKEN=
ZAPI_CLIENT_TOKEN=
BREVO_API_KEY=
GEMINI_API_KEY=
META_CAPI_TOKEN=
META_PIXEL_ID=
META_AD_ACCOUNT_ID=
META_PAGE_ID=
META_BUSINESS_ID=
